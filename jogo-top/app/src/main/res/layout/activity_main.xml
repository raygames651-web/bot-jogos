<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0d0d0d">

    <!-- ESPAÇO ANÚNCIO TOPO (320x50) -->
    <LinearLayout
        android:id="@+id/adContainerTop"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:background="#1a1a1a"
        android:gravity="center"
        android:orientation="vertical">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="[ESPAÇO ANÚNCIO TOPO]"
            android:textColor="#444"
            android:textSize="10dp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/btn_star_big_on"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="QUIZ PREMIADO TOP"
                android:textColor="#FFD700"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginLeft="10dp"/>
        </LinearLayout>

        <!-- Pontuação -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="20dp">
            <TextView
                android:id="@+id/tvPontos"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="⭐ Pontos: 0"
                android:textColor="#00ff88"
                android:textSize="16sp"/>
            <TextView
                android:id="@+id/tvNivel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nível: 1"
                android:textColor="#888"
                android:textSize="14sp"/>
        </LinearLayout>

        <!-- Pergunta -->
        <TextView
            android:id="@+id/tvPergunta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Carregando..."
            android:textColor="#fff"
            android:textSize="18sp"
            android:gravity="center"
            android:padding="20dp"
            android:layout_marginTop="30dp"
            android:background="#1a1a2e"/>

        <!-- Opções -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="20dp">

            <Button
                android:id="@+id/btnA"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="A) ..."
                android:textColor="#fff"
                android:textSize="14sp"
                android:background="#16213e"
                android:layout_marginBottom="8dp"/>

            <Button
                android:id="@+id/btnB"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="B) ..."
                android:textColor="#fff"
                android:textSize="14sp"
                android:background="#16213e"
                android:layout_marginBottom="8dp"/>

            <Button
                android:id="@+id/btnC"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="C) ..."
                android:textColor="#fff"
                android:textSize="14sp"
                android:background="#16213e"
                android:layout_marginBottom="8dp"/>

            <Button
                android:id="@+id/btnD"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="D) ..."
                android:textColor="#fff"
                android:textSize="14sp"
                android:background="#16213e"/>

        </LinearLayout>

    </LinearLayout>

    <!-- ESPAÇO ANÚNCIO RODAPÉ (320x50) -->
    <LinearLayout
        android:id="@+id/adContainerBottom"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:background="#1a1a1a"
        android:gravity="center"
        android:orientation="vertical">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="[ESPAÇO ANÚNCIO RODAPÉ]"
            android:textColor="#444"
            android:textSize="10dp" />
    </LinearLayout>

</LinearLayout>